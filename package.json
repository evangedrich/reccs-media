{
	"name": "my-next-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "next lint",
		"sync": "tsx scripts/sync-d1.ts",
		"sync:images": "tsx scripts/sync-images.ts",
		"subset-fonts": "tsx scripts/subset-fonts.ts",
		"update-map": "python3 scripts/update-region-polygons.py",
		"deploy": "pnpm sync && pnpm subset-fonts && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "pnpm subset-fonts && opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "pnpm subset-fonts && opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.17.1",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.0",
		"@types/earcut": "^3.0.0",
		"@types/three": "0.182.0",
		"earcut": "^3.0.2",
		"html-react-parser": "^6.0.1",
		"next": "^16.2.3",
		"react": "19.1.5",
		"react-dom": "19.1.5",
		"react-markdown": "^10.1.0",
		"three": "0.182.0",
		"three-stdlib": "^2.36.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"subset-font": "^2.5.0",
		"tailwindcss": "^4",
		"tsx": "^4.20.0",
		"typescript": "^5.7.4",
		"wrangler": "^4.65.0"
	}
}
